{
  "name": "@seyoon20087/react-loadable",
  "publishConfig": {
    "access": "public"
  },
  "version": "6.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seyoon20087/react-loadable-revised.git"
  },
  "exports": {
    ".": {
      "default": "./lib/index.mjs",
      "require": "./lib/index.cjs",
      "types": "./index.d.ts"
    },
    "./webpack": {
      "default": "./lib/webpack.mjs",
      "require": "./lib/webpack.cjs"
    },
    "./babel": {
      "default": "./lib/babel.mjs",
      "require": "./lib/babel.cjs"
    }
  },
  "scripts": {
    "test": "jest --coverage",
    "build": "tsdown",
    "start": "yarn build && webpack && babel-node example/server.js",
    "prepare": "yarn build"
  },
  "dependencies": {
    "@types/react": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.1.2",
    "@babel/node": "^7.0.0",
    "@babel/plugin-proposal-class-properties": "^7.1.0",
    "@babel/plugin-transform-async-to-generator": "^7.1.0",
    "@babel/plugin-transform-object-assign": "^7.0.0",
    "@babel/preset-env": "^7.1.0",
    "@babel/preset-react": "^7.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-test-renderer": "^19.2.7",
    "tsdown": "^0.22.9"
  },
  "peerDependencies": {
    "react": "*"
  }
}
